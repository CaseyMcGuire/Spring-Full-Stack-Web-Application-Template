{
  "name": "application",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && vite build",
    "watch": "vite build --watch --mode development --outDir build/resources/main/static/bundles",
    "relay-compiler": "spa-kit-compile-relay --schema-dir src/main/resources/schema --out src/main/resources/relay/schema.graphql"
  },
  "relay": {
    "src": "src/main/web-frontend",
    "language": "typescript",
    "schema": "src/main/resources/relay/schema.graphql",
    "artifactDirectory": "./src/main/web-frontend/__generated__",
    "eagerEsModules": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CaseyMcGuire/puzzlr-kotlin.git"
  },
  "author": "Casey McGuire",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/CaseyMcGuire/puzzlr-kotlin/issues"
  },
  "homepage": "https://github.com/CaseyMcGuire/puzzlr-kotlin#readme",
  "dependencies": {
    "@graphiql/toolkit": "^0.12.0",
    "@spa-kit/react": "^0.0.1",
    "@spa-kit/react-relay": "^0.0.1",
    "@spa-kit/react-router": "^0.0.1",
    "@stylexjs/stylex": "^0.18.3",
    "graphiql": "^5.2.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-relay": "^21.0.0",
    "react-router": "^7.15.1",
    "relay-runtime": "^21.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/plugin-transform-runtime": "^7.29.7",
    "@babel/runtime": "^7.29.7",
    "@rolldown/plugin-babel": "^0.2.3",
    "@spa-kit/node": "^0.0.2",
    "@stylexjs/unplugin": "^0.18.3",
    "@types/js-beautify": "^1.14.3",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/react-relay": "^18.2.1",
    "@types/relay-runtime": "^20.1.1",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-relay": "^21.0.0",
    "graphql": "^16.14.0",
    "js-beautify": "^1.15.4",
    "relay-compiler": "^21.0.0",
    "rolldown": "~1.1.5",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vite-plugin-checker": "^0.14.4"
  }
}
